{
  "name": "n8n-nodes-youtube-dl",
  "version": "0.1.0",
  "description": "n8n community node for downloading YouTube videos using ytdl-core",
  "keywords": [
    "n8n-community-node-package",
    "youtube",
    "download",
    "video",
    "audio"
  ],
  "license": "MIT",
  "homepage": "https://github.com/prakashmaheshwaran/n8n-nodes-youtube-dl",
  "author": {
    "name": "Prakash Maheshwaran",
    "email": "prakash@example.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prakashmaheshwaran/n8n-nodes-youtube-dl.git"
  },
  "bugs": {
    "url": "https://github.com/prakashmaheshwaran/n8n-nodes-youtube-dl/issues"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes --write",
    "lint": "eslint nodes package.json --ext .ts,.json --quiet",
    "lintfix": "eslint nodes package.json --ext .ts,.json --fix",
    "prepublishOnly": "npm run build && npm run lint -s"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [],
    "nodes": [
      "dist/nodes/YouTubeDL/YouTubeDL.node.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.0",
    "gulp": "^4.0.2",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.13.5",
    "n8n-workflow": "^1.29.1"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
