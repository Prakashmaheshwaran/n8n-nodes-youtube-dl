{
  "name": "n8n-nodes-youtube-dl",
  "version": "2.1.3",
  "description": "YouTube video/audio downloader for n8n using yt-dlp",
  "keywords": [
    "n8n-community-node-package",
    "youtube",
    "download",
    "video",
    "audio",
    "ytdl"
  ],
  "license": "MIT",
  "homepage": "https://github.com/prakashmaheshwaran/n8n-nodes-youtube-dl",
  "author": {
    "name": "Prakash Maheshwaran",
    "email": "your-email@example.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prakashmaheshwaran/n8n-nodes-youtube-dl.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes --write",
    "lint": "eslint nodes/**/*.ts --fix",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.js",
    "test": "jest"
  },
  "files": [
    "dist",
    "scripts"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/YouTubeDLCookies.credentials.js"
    ],
    "nodes": [
      "dist/nodes/YouTubeDL/YouTubeDL.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "^1.0.0",
    "prettier": "^3.0.3",
    "typescript": "^5.2.2"
  },
  "dependencies": {},
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
